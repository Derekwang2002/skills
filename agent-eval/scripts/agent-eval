#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BUNDLED_SRC="$SCRIPT_DIR"
REPO_SRC="$(cd "$SCRIPT_DIR/../../.." && pwd)/src"
PYTHONPATH_ENTRIES=()

if [[ -d "$BUNDLED_SRC/agent_eval" ]]; then
  PYTHONPATH_ENTRIES+=("$BUNDLED_SRC")
fi

if [[ -d "$REPO_SRC/agent_eval" ]]; then
  PYTHONPATH_ENTRIES+=("$REPO_SRC")
fi

if [[ ${#PYTHONPATH_ENTRIES[@]} -gt 0 ]]; then
  IFS=:
  export PYTHONPATH="${PYTHONPATH_ENTRIES[*]}${PYTHONPATH:+:$PYTHONPATH}"
  unset IFS
fi

"${PYTHON:-python3}" -m agent_eval "$@"
